{
    "extends": "../tinycld/tsconfig.package-base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "~/tinycld/calc/*": ["./tinycld/calc/*"],
            "@tinycld/core/*": ["../tinycld/core/*"],
            "@tinycld/drive/*": ["../drive/tinycld/drive/*"],
            "@tinycld/app-generated/*": ["../tinycld/lib/generated/*"]
        }
    },
    "include": ["tinycld/**/*.ts", "tinycld/**/*.tsx", "../tinycld/uniwind-types.d.ts"],
    "exclude": ["node_modules", "server", "pb-migrations", "tests/**/*.spec.ts"]
}
